#!/bin/bash
# Divi5 Generator launcher — starts the local Node server and opens it in Chrome.

PORT=3747
URL="http://localhost:${PORT}"

# --- Locate the app's server.js -------------------------------------------
# 1) Known external-drive repo location  2) plugin cache fallbacks
CANDIDATES=(
  "/Volumes/External/Divi5Generate/app/server.js"
)

APP_SERVER=""
for c in "${CANDIDATES[@]}"; do
  if [ -f "$c" ]; then APP_SERVER="$c"; break; fi
done

# Fallback: search plugin cache / marketplaces if the drive isn't mounted
if [ -z "$APP_SERVER" ]; then
  APP_SERVER=$(find "$HOME/.claude/plugins/cache" "$HOME/.claude/plugins/marketplaces" \
    -maxdepth 8 -name "server.js" -path "*divi5generate*/app/*" 2>/dev/null | head -1)
fi

if [ -z "$APP_SERVER" ] || [ ! -f "$APP_SERVER" ]; then
  osascript -e 'display alert "Divi5 Generator" message "Could not find the app (app/server.js). Is the external drive mounted or the plugin installed?" as critical'
  exit 1
fi

APP_DIR="$(cd "$(dirname "$APP_SERVER")" && pwd)"

# --- Find Node ------------------------------------------------------------
NODE_BIN="$(command -v node)"
[ -z "$NODE_BIN" ] && for p in /opt/homebrew/bin/node /usr/local/bin/node; do
  [ -x "$p" ] && NODE_BIN="$p" && break
done
if [ -z "$NODE_BIN" ]; then
  osascript -e 'display alert "Divi5 Generator" message "Node.js was not found. Install Node and try again." as critical'
  exit 1
fi

# --- Restart cleanly ------------------------------------------------------
# Kill anything already bound to the port, then start fresh
lsof -ti tcp:${PORT} | xargs kill -9 2>/dev/null || true
sleep 0.5

# Install deps on first run
[ ! -d "$APP_DIR/node_modules" ] && (cd "$APP_DIR" && npm install --silent)

# Start server detached so it keeps running after this script exits
cd "$APP_DIR"
nohup "$NODE_BIN" "$APP_SERVER" >/tmp/divi5generator.log 2>&1 &

# Wait up to 12s for it to answer
for i in $(seq 1 12); do
  sleep 1
  curl -s "${URL}/prereqs" >/dev/null 2>&1 && break
done

# --- Open in Chrome -------------------------------------------------------
if open -a "Google Chrome" "$URL" 2>/dev/null; then
  :
else
  # Chrome not installed — fall back to default browser
  open "$URL"
fi
