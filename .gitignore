# Large Divi 5 design-system reference data (96MB) — loaded locally, not shipped in git.
# Source: ElegantThemes "Black Friday 2025 Divi 5 Freebie" design-system export.
skills/divi5-page-generator/references/Divi-5-Design-System/

.DS_Store

# Generated pages, previews, tokens and generate-*.js scripts no longer land in
# the repo — the skills and app write everything to ~/Desktop/Divi5 Pages
# (override with the DIVI5_OUT env var). Safety net in case an old workflow
# writes a stray artefact at the repo root:
/*-landing-page.json
/*-section.json
/*-seo-meta.json
/*-schema.json
/*.tokens.js
/generate-*.js
/payload*.json
/preview-*.html

# Same rule inside the page-generator skill root: demo/generated artefacts
# (compare screenshots, previews, brand-specific generate scripts and JSON)
# must not be committed — they belong in ~/Desktop/Divi5 Pages. Legit fixtures
# live in scripts/, references/ and examples/, which are NOT matched below.
skills/divi5-page-generator/compare-*.png
skills/divi5-page-generator/preview-*.html
skills/divi5-page-generator/preview-*.png
skills/divi5-page-generator/generate-*.js
skills/divi5-page-generator/*-landing-page.json
skills/divi5-page-generator/*-registry.json
skills/divi5-page-generator/*-seo-meta.json
skills/divi5-page-generator/__unlink_probe*

# Divi5 Generator — dev tooling only (not shipped in the installable zip).
# vendor/ is installed by `composer install`; tests/.phpunit.cache is PHPUnit's
# result cache. Both are excluded from the zip by build-plugin-zip.sh.
plugin/divi5-generator/vendor/
plugin/divi5-generator/tests/.phpunit.cache/
plugin/divi5-generator/package-lock.json
plugin/divi5-generator/node_modules/

# Root vendor/ + composer files are unused cruft — the WordPress plugin under
# plugin/divi5-generator/ carries its own vendor/. Nothing in skills/, commands/
# or the plugin itself requires the root autoload.
/vendor/
/composer.json
/composer.lock

# macOS app bundle — local launcher convenience, not referenced by any skill or
# command by path (launch-app and /launch use app/server.js directly).
/Divi5 Generator.app/

# Dev-only docs and planning notes — not loaded at plugin runtime.
/docs/
/DEVELOPMENT.md
/PORTABLE-LIBRARY-PLAN.md
/DESIGN-SYSTEM-REUSE.notes.md
